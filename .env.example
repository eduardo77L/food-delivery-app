# JWT (mesmo valor em todos os serviços que validam token)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Portas dos serviços
API_GATEWAY_PORT=3001
AUTH_SERVICE_PORT=3002
USER_SERVICE_PORT=3003
RESTAURANT_SERVICE_PORT=3004
ORDER_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# URLs internas (Docker Compose)
AUTH_SERVICE_URL=http://auth-service:3002
USER_SERVICE_URL=http://user-service:3003
RESTAURANT_SERVICE_URL=http://restaurant-service:3004
ORDER_SERVICE_URL=http://order-service:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006

# Bancos (desenvolvimento local sem Docker nos serviços)
AUTH_DATABASE_URL=postgresql://user:pass@localhost:5432/authdb
USER_DATABASE_URL=postgresql://user:pass@localhost:5433/userdb
RESTAURANT_DATABASE_URL=postgresql://user:pass@localhost:5434/restaurantdb
ORDER_DATABASE_URL=postgresql://user:pass@localhost:5435/orderdb

# Frontend
VITE_API_URL=http://localhost:3001
